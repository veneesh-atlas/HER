# ── HER Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── AI Provider ─────────────────────────────────────────────
# Which provider to use: "gemini" | "nvidia"
HER_PROVIDER=nvidia

# ── Google Gemini ───────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── NVIDIA NIM API Keys ─────────────────────────────────────
# Get your API keys at: https://build.nvidia.com/
# Each capability uses its own key for clean separation.

# Chat (Mistral Large 3)
NVIDIA_CHAT_API_KEY=your_chat_key_here

# Image Generation (Stable Diffusion 3 Medium)
NVIDIA_IMAGE_API_KEY=your_image_key_here

# Vision / Image Understanding (Gemma 3 27B — future Step 11D)
NVIDIA_VISION_API_KEY=your_vision_key_here

# ── Supabase (Public Frontend Keys) ────────────────────────
# Project URL: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anon/Public key: Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── OpenAI (future) ────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic (future) ─────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
